coverage/
*.tsbuildinfo

# ── Secrets — never commit these ────────────────────────────────
.env
.env.local
.env.*.local

# ── SQLite DB (generated by the ingestion pipeline) ─────────────
# Commit anton-rx-chat/data/anton_rx.db ONLY after running the
# ingestion pipeline and copying the file there for deployment.
# Uncomment the next line to exclude it from version control:
# *.db
# *.db-shm
# *.db-wal

# ── Logs ────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS / Editor ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vercel
.idea/
.vscode/
